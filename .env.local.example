# Firebase Client SDK (public - prefijo NEXT_PUBLIC_)
NEXT_PUBLIC_FIREBASE_API_KEY=
NEXT_PUBLIC_FIREBASE_AUTH_DOMAIN=
NEXT_PUBLIC_FIREBASE_PROJECT_ID=
NEXT_PUBLIC_FIREBASE_STORAGE_BUCKET=
NEXT_PUBLIC_FIREBASE_MESSAGING_SENDER_ID=
NEXT_PUBLIC_FIREBASE_APP_ID=

# Firebase Admin SDK (privado - NO exponer al cliente)
FIREBASE_ADMIN_PROJECT_ID=
FIREBASE_ADMIN_CLIENT_EMAIL=
FIREBASE_ADMIN_PRIVATE_KEY=

# Notificaciones por correo (Resend) - opcional
# Si RESEND_API_KEY está vacío, las notificaciones se desactivan sin romper nada.
RESEND_API_KEY=
# Remitente verificado en Resend. Mientras no verifiques el dominio, usa onboarding@resend.dev
RESEND_FROM="Fundación INNOVALIA <notificaciones@innovalia.org>"
# URL pública del sitio (para el botón del correo). Por defecto: https://innovalia.org
NEXT_PUBLIC_SITE_URL=https://innovalia.org
